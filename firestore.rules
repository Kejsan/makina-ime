rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function ownsVehicle(vehicleId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/vehicles/$(vehicleId))
        && get(/databases/$(database)/documents/vehicles/$(vehicleId)).data.userId == request.auth.uid;
    }

    function vehicleOwnerUnchanged() {
      return !('userId' in request.resource.data)
        || request.resource.data.userId == resource.data.userId;
    }

    function hasOnly(keys) {
      return request.resource.data.keys().hasOnly(keys);
    }

    function validLinkedSourceCreate() {
      return request.resource.data.sourceType in ['manual', 'service'];
    }

    function canDeleteClientExpense() {
      return !('sourceType' in resource.data)
        || resource.data.sourceType == 'manual'
        || resource.data.sourceType == 'service';
    }

    match /vehicles/{vehicleId} {
      allow create: if isOwner(request.resource.data.userId);
      allow read: if isOwner(resource.data.userId);
      allow delete: if false;
      allow update: if isOwner(resource.data.userId) && vehicleOwnerUnchanged();

      match /services/{serviceId} {
        allow read, delete: if ownsVehicle(vehicleId);
        allow create: if ownsVehicle(vehicleId)
          && (!('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid);
        allow update: if ownsVehicle(vehicleId)
          && (!('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid);
      }

      match /expenses/{expenseId} {
        allow read: if ownsVehicle(vehicleId);
        allow delete: if ownsVehicle(vehicleId) && canDeleteClientExpense();
        allow create: if ownsVehicle(vehicleId)
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.vehicleId == vehicleId
          && validLinkedSourceCreate()
          && hasOnly(['userId', 'vehicleId', 'category', 'amount', 'date', 'notes', 'sourceType', 'sourceId', 'sourceLabel', 'createdAt']);
        allow update: if false;
      }

      match /documents/{documentId} {
        allow read: if ownsVehicle(vehicleId);
        allow delete: if ownsVehicle(vehicleId)
          && (!('storageProvider' in resource.data) || resource.data.storageProvider != 'r2');
        allow create, update: if false;
      }
    }

    match /reminders/{reminderId} {
      allow create: if isOwner(request.resource.data.userId)
        && ownsVehicle(request.resource.data.vehicleId);
      allow read, delete: if isOwner(resource.data.userId);
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.vehicleId == resource.data.vehicleId;
    }

    match /users/{userId} {
      allow create: if isOwner(userId);
      allow read, update, delete: if isOwner(userId);

      match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(userId);
        allow create: if isOwner(userId);
      }
    }

    match /accountDeletionRequests/{requestId} {
      allow create: if isOwner(request.resource.data.userId)
        && request.resource.data.status == 'requested'
        && hasOnly(['userId', 'email', 'status', 'createdAt']);
      allow read: if isOwner(resource.data.userId);
      allow update, delete: if false;
    }

    match /rateLimits/{rateLimitId} {
      allow read, write: if false;
    }
  }
}
