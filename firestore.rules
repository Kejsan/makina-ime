rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function signedEmail() {
      return request.auth.token.email;
    }

    function hasOnly(keys) {
      return request.resource.data.keys().hasOnly(keys);
    }

    function memberPath(orgId, uid) {
      return /databases/$(database)/documents/organizationMembers/$(orgId + '_' + uid);
    }

    function invitePath(orgId, email) {
      return /databases/$(database)/documents/organizationInvites/$(orgId + '_' + email);
    }

    function isOrgMember(orgId) {
      return isSignedIn()
        && exists(memberPath(orgId, request.auth.uid))
        && get(memberPath(orgId, request.auth.uid)).data.status == 'active';
    }

    function orgRole(orgId) {
      return get(memberPath(orgId, request.auth.uid)).data.role;
    }

    function canViewOrg(orgId) {
      return isOrgMember(orgId);
    }

    function canDriverOrg(orgId) {
      return isOrgMember(orgId)
        && orgRole(orgId) in ['owner', 'admin', 'manager', 'driver'];
    }

    function canEditOrg(orgId) {
      return isOrgMember(orgId)
        && orgRole(orgId) in ['owner', 'admin', 'manager'];
    }

    function canManageOrg(orgId) {
      return isOrgMember(orgId)
        && orgRole(orgId) in ['owner', 'admin'];
    }

    function canOwnNewOrganization(orgId) {
      return isSignedIn()
        && getAfter(/databases/$(database)/documents/organizations/$(orgId)).data.createdBy == request.auth.uid;
    }

    function createsOwnOrganization(orgId) {
      return isSignedIn()
        && existsAfter(/databases/$(database)/documents/organizations/$(orgId))
        && getAfter(/databases/$(database)/documents/organizations/$(orgId)).data.createdBy == request.auth.uid;
    }

    function createsOwnerMembership(orgId) {
      return isSignedIn()
        && existsAfter(memberPath(orgId, request.auth.uid))
        && getAfter(memberPath(orgId, request.auth.uid)).data.organizationId == orgId
        && getAfter(memberPath(orgId, request.auth.uid)).data.userId == request.auth.uid
        && getAfter(memberPath(orgId, request.auth.uid)).data.role == 'owner'
        && getAfter(memberPath(orgId, request.auth.uid)).data.status == 'active';
    }

    function validBusinessSettingsData() {
      return request.resource.data.keys().hasOnly(['defaultReminderLeadTimeDays', 'inspectionFailureCreatesWorkOrder', 'preferredCurrency', 'createdAt', 'updatedAt']);
    }

    function canAcceptInvite(orgId, role) {
      return isSignedIn()
        && exists(invitePath(orgId, signedEmail()))
        && get(invitePath(orgId, signedEmail())).data.email == signedEmail()
        && get(invitePath(orgId, signedEmail())).data.organizationId == orgId
        && get(invitePath(orgId, signedEmail())).data.role == role
        && get(invitePath(orgId, signedEmail())).data.status == 'pending';
    }

    function isPersonalVehicleData(data) {
      return !('ownerType' in data) || data.ownerType == 'personal';
    }

    function canReadVehicleData(data) {
      return (isPersonalVehicleData(data) && isOwner(data.userId))
        || (data.ownerType == 'organization' && canViewOrg(data.ownerId));
    }

    function canEditVehicleData(data) {
      return (isPersonalVehicleData(data) && isOwner(data.userId))
        || (data.ownerType == 'organization' && canEditOrg(data.ownerId));
    }

    function canDriverVehicleData(data) {
      return (isPersonalVehicleData(data) && isOwner(data.userId))
        || (data.ownerType == 'organization' && canDriverOrg(data.ownerId));
    }

    function ownsVehicle(vehicleId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/vehicles/$(vehicleId))
        && canReadVehicleData(get(/databases/$(database)/documents/vehicles/$(vehicleId)).data);
    }

    function canEditVehicle(vehicleId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/vehicles/$(vehicleId))
        && canEditVehicleData(get(/databases/$(database)/documents/vehicles/$(vehicleId)).data);
    }

    function canDriverVehicle(vehicleId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/vehicles/$(vehicleId))
        && canDriverVehicleData(get(/databases/$(database)/documents/vehicles/$(vehicleId)).data);
    }

    function vehicleOwnerUnchanged() {
      return (!('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId)
        && (!('ownerType' in request.resource.data) || request.resource.data.ownerType == resource.data.ownerType)
        && (!('ownerId' in request.resource.data) || request.resource.data.ownerId == resource.data.ownerId);
    }

    function validLinkedSourceCreate() {
      return request.resource.data.sourceType in ['manual', 'service'];
    }

    function canDeleteClientExpense() {
      return !('sourceType' in resource.data)
        || resource.data.sourceType == 'manual'
        || resource.data.sourceType == 'service';
    }

    function canUpdateManualExpense(vehicleId) {
      return canEditVehicle(vehicleId)
        && (!('sourceType' in resource.data) || resource.data.sourceType == 'manual')
        && (!('userId' in resource.data) || request.resource.data.userId == resource.data.userId)
        && (!('vehicleId' in resource.data) || resource.data.vehicleId == vehicleId)
        && (!('vehicleId' in request.resource.data) || request.resource.data.vehicleId == vehicleId)
        && (!('sourceType' in request.resource.data) || request.resource.data.sourceType == 'manual')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['category', 'amount', 'date', 'notes', 'updatedAt']);
    }

    match /organizations/{orgId} {
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid;
      allow read: if canViewOrg(orgId);
      allow update: if canManageOrg(orgId);
      allow delete: if isOrgMember(orgId) && orgRole(orgId) == 'owner';

      match /businessSettings/{settingId} {
        allow read: if canViewOrg(orgId);
        allow create: if validBusinessSettingsData()
          && (canManageOrg(orgId) || createsOwnOrganization(orgId) || createsOwnerMembership(orgId));
        allow update: if validBusinessSettingsData() && canManageOrg(orgId);
        allow delete: if canManageOrg(orgId);
      }

      match /vendors/{vendorId} {
        allow read: if canViewOrg(orgId);
        allow create, update, delete: if canEditOrg(orgId)
          && request.resource.data.organizationId == orgId;
      }
    }

    match /organizationMembers/{memberId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || canViewOrg(resource.data.organizationId));
      allow create: if isSignedIn()
        && memberId == request.resource.data.organizationId + '_' + request.resource.data.userId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'active'
        && (
          (request.resource.data.role == 'owner' && canOwnNewOrganization(request.resource.data.organizationId))
          || canAcceptInvite(request.resource.data.organizationId, request.resource.data.role)
        );
      allow update: if canManageOrg(resource.data.organizationId)
        && request.resource.data.organizationId == resource.data.organizationId
        && request.resource.data.userId == resource.data.userId;
      allow delete: if canManageOrg(resource.data.organizationId);
    }

    match /organizationInvites/{inviteId} {
      allow create: if canManageOrg(request.resource.data.organizationId)
        && inviteId == request.resource.data.organizationId + '_' + request.resource.data.email
        && request.resource.data.status == 'pending';
      allow read: if canManageOrg(resource.data.organizationId)
        || (isSignedIn() && resource.data.email == signedEmail());
      allow update: if canManageOrg(resource.data.organizationId)
        || (isSignedIn()
          && resource.data.email == signedEmail()
          && resource.data.status == 'pending'
          && request.resource.data.status == 'accepted'
          && request.resource.data.organizationId == resource.data.organizationId
          && request.resource.data.email == resource.data.email
          && request.resource.data.role == resource.data.role);
      allow delete: if canManageOrg(resource.data.organizationId);
    }

    match /vehicles/{vehicleId} {
      allow create: if (
          request.resource.data.ownerType == 'organization'
          && request.resource.data.ownerId == request.resource.data.organizationId
          && canEditOrg(request.resource.data.ownerId)
          && request.resource.data.createdBy == request.auth.uid
        ) || (
          isPersonalVehicleData(request.resource.data)
          && isOwner(request.resource.data.userId)
        );
      allow read: if canReadVehicleData(resource.data);
      allow delete: if false;
      allow update: if canEditVehicleData(resource.data) && vehicleOwnerUnchanged();

      match /services/{serviceId} {
        allow read: if ownsVehicle(vehicleId);
        allow delete: if canEditVehicle(vehicleId);
        allow create: if canDriverVehicle(vehicleId)
          && (!('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid);
        allow update: if canEditVehicle(vehicleId)
          && (!('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid);
      }

      match /expenses/{expenseId} {
        allow read: if ownsVehicle(vehicleId);
        allow delete: if canEditVehicle(vehicleId) && canDeleteClientExpense();
        allow create: if canDriverVehicle(vehicleId)
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.vehicleId == vehicleId
          && validLinkedSourceCreate()
          && request.resource.data.keys().hasOnly(['userId', 'vehicleId', 'category', 'amount', 'date', 'notes', 'sourceType', 'sourceId', 'sourceLabel', 'createdAt']);
        allow update: if canUpdateManualExpense(vehicleId);
      }

      match /documents/{documentId} {
        allow read: if ownsVehicle(vehicleId);
        allow delete: if canEditVehicle(vehicleId)
          && (!('storageProvider' in resource.data) || resource.data.storageProvider != 'r2');
        allow create, update: if false;
      }

      match /inspections/{inspectionId} {
        allow read: if ownsVehicle(vehicleId);
        allow create: if canDriverVehicle(vehicleId)
          && request.resource.data.vehicleId == vehicleId;
        allow update, delete: if canEditVehicle(vehicleId);
      }

      match /issues/{issueId} {
        allow read: if ownsVehicle(vehicleId);
        allow create: if canDriverVehicle(vehicleId)
          && request.resource.data.vehicleId == vehicleId;
        allow update, delete: if canEditVehicle(vehicleId);
      }

      match /workOrders/{workOrderId} {
        allow read: if ownsVehicle(vehicleId);
        allow create, update, delete: if canEditVehicle(vehicleId)
          && request.resource.data.vehicleId == vehicleId;
      }
    }

    match /reminders/{reminderId} {
      allow create: if (
          request.resource.data.ownerType == 'organization'
          && canDriverOrg(request.resource.data.ownerId)
          && canDriverVehicle(request.resource.data.vehicleId)
        ) || (
          isOwner(request.resource.data.userId)
          && canDriverVehicle(request.resource.data.vehicleId)
        );
      allow read, delete: if (
          resource.data.ownerType == 'organization'
          && canViewOrg(resource.data.ownerId)
        ) || isOwner(resource.data.userId);
      allow update: if (
          resource.data.ownerType == 'organization'
          && canDriverOrg(resource.data.ownerId)
          && request.resource.data.ownerId == resource.data.ownerId
          && request.resource.data.vehicleId == resource.data.vehicleId
        ) || (
          isOwner(resource.data.userId)
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.vehicleId == resource.data.vehicleId
        );
    }

    match /users/{userId} {
      allow create: if isOwner(userId);
      allow read, update, delete: if isOwner(userId);

      match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(userId);
        allow create: if isOwner(userId);
      }
    }

    match /accountDeletionRequests/{requestId} {
      allow create: if isOwner(request.resource.data.userId)
        && request.resource.data.status == 'requested'
        && hasOnly(['userId', 'email', 'status', 'createdAt']);
      allow read: if isOwner(resource.data.userId);
      allow update, delete: if false;
    }

    match /rateLimits/{rateLimitId} {
      allow read, write: if false;
    }
  }
}
